{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "booking-route": {
        "ClusterId": "reservas-cluster",
        "Match": {
          "Path": "/api/v1/mathias-rivera/booking/{**remainder}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/v1/reservas/{**remainder}"
          }
        ]
      },
      "alojamientos-route": {
        "ClusterId": "alojamientos-cluster",
        "Match": {
          "Path": "/api/v1/mathias-rivera/alojamientos/{**remainder}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/v1/alojamientos/{**remainder}"
          }
        ]
      },
      "calendario-route": {
        "ClusterId": "alojamientos-cluster",
        "Match": {
          "Path": "/api/v1/mathias-rivera/calendario/{**remainder}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/v1/calendario/{**remainder}"
          }
        ]
      }
    },
    "Clusters": {
      "reservas-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5003/"
          }
        }
      },
      "alojamientos-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002/"
          }
        }
      }
    }
  }
}
